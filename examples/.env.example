# =============================================================================
# Enhanced RLM - Project Environment Configuration
# =============================================================================
# Copy this file to .env in your project root and customize the values.
# IMPORTANT: .env is gitignored and must NEVER be committed to version control.
#
# This file configures the optional documentation website feature that turns
# your .claude/topics/*.md knowledge base files into a static HTML website.
# =============================================================================

# -----------------------------------------------------------------------------
# Documentation Website
# -----------------------------------------------------------------------------
# Set to "true" to enable the documentation website for this project.
# When enabled, Claude will auto-build and deploy the website whenever
# topic files in .claude/topics/ are modified.
# Set to "false" if this project does not need a documentation website.
WEBSITE_ENABLED=false

# Website URL prefix: creates {prefix}.{domain} (e.g., "docs" → docs.example.com)
WEBSITE_PREFIX=docs

# Base domain for the website (e.g., "example.com")
WEBSITE_DOMAIN=example.com

# Display title shown in the website header and login page
WEBSITE_TITLE=My Project Knowledge Base

# Subtitle shown below the title
WEBSITE_SUBTITLE=Project Documentation

# SSH host alias or hostname for deployment (must be configured in ~/.ssh/config)
WEBSITE_DEPLOY_HOST=myserver

# Remote path where index.html will be deployed via scp
# Supports placeholders: {prefix} and {domain} are replaced with values above
WEBSITE_DEPLOY_PATH=/var/www/{prefix}.{domain}/index.html

# -----------------------------------------------------------------------------
# Website Authentication
# -----------------------------------------------------------------------------
# Client-side login credentials for the documentation website.
# Format: email:password:display_name:role (comma-separated for multiple users)
# Roles: "admin" or "user" (currently cosmetic, both have full read access)
#
# Example with multiple users:
# WEBSITE_USERS=admin@example.com:SecurePass123:Admin User:admin,reader@example.com:ReadPass456:Reader:user
WEBSITE_USERS=admin@example.com:changeme:Admin User:admin

# -----------------------------------------------------------------------------
# Python Path (optional, for build script)
# -----------------------------------------------------------------------------
# If your system Python is not on PATH, specify the full path here.
# Leave empty to use the default "python3" or "python" command.
# PYTHON_PATH=/usr/bin/python3
